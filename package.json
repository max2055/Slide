{
  "name": "slide",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Slide — AI-Powered Database Operations Platform",
  "scripts": {
    "dev": "pnpm --filter slide-api dev & pnpm --filter slide-frontend dev",
