# Slide — Database Operations Platform
# Copy to .env and adjust values

# ── Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=db_ops_ai

# ── AI / LLM ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250929
OPENAI_API_KEY=sk-...

# ── Auth ──
JWT_SECRET_KEY=your-secret-key-min-32-chars

# ── Server ──
BACKEND_PORT=3000
FRONTEND_PORT=5173
AGENT_WS_PORT=28888
