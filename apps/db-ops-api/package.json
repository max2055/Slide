{
  "name": "slide-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "init-db": "tsx init-db.ts",
    "test-db": "tsx test-db.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx tests/smoke-test.ts",
    "smoke:ci": "tsx tests/smoke-test.ts 2>&1 | tee smoke-report.txt",
    "smoke:deep": "tsx tests/deep-smoke.ts",
    "schema:check": "tsx tests/schema-validator.ts",
    "test:all": "tsx tests/smoke-test.ts && tsx tests/deep-smoke.ts && tsx tests/schema-validator.ts",
    "gateway:start": "echo 'Gateway removed — use DirectAdapter directly'",
    "gateway:stop": "echo 'Gateway removed'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@elastic/elasticsearch": "^8.11.0",
    "@fastify/cors": "^8.5.0",
    "@sinclair/typebox": "^0.34.49",
    "@slide/agent-core": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "cron": "^4.4.0",
    "dmdb": "^1.0.48286",
    "dotenv": "^17.4.1",
    "ejs": "^5.0.2",
    "fastify": "^4.24.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mysql2": "^3.20.0",
    "node-sql-parser": "^5.4.0",
    "openai": "^4.28.0",
    "oracledb": "^6.10.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "simple-statistics": "^7.8.9",
    "ws": "^8.20.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/oracledb": "^6.10.2",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^4.1.4"
  }
}
