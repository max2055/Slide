<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %> - <%= instanceName %></title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; padding: 20px; color: #333333; font: 400 14px/1.6 -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; background: #ffffff; }
    h1 { font-size: 22px; font-weight: 700; line-height: 1.2; color: #333; border-bottom: 2px solid <%= accentColor %>; padding-bottom: 10px; margin: 0 0 16px 0; }
    h2 { font-size: 16px; font-weight: 600; line-height: 1.3; color: #555555; border-bottom: 1px solid #ddd; padding-bottom: 6px; margin: 24px 0 12px 0; }
    p { margin: 6px 0; }
    strong { font-weight: 600; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { padding: 10px; text-align: left; border-bottom: 1px solid #ddd; }
    th { background: #f5f5f5; font-size: 11px; font-weight: 600; text-transform: uppercase; }
    td { font-size: 13px; line-height: 1.4; }
    .summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin: 20px 0; }
    .card { padding: 16px; border-radius: 8px; background: #f5f5f5; }
    .card.ok { background: #e8f5e9; }
    .card.warning { background: #fff3e0; }
    .card.critical { background: #ffebee; }
    .metric { font-size: 22px; font-weight: 700; line-height: 1.1; }
    .label { font-size: 11px; font-weight: 600; text-transform: uppercase; line-height: 1.3; color: #666; }
    .badge { padding: 4px 8px; border-radius: 4px; font-size: 12px; }
    .badge.high { background: #ffebee; color: #c62828; }
    .badge.medium { background: #fff3e0; color: #ef6c00; }
    code { background: #f5f5f5; padding: 2px 6px; border-radius: 3px; font-size: 12px; }
  </style>
</head>
<body>
  <h1><%= icon %> <%= title %></h1>
  <p><strong>实例:</strong> <%= instanceName %></p>
  <p><strong>生成时间:</strong> <%= generatedAt %></p>
  <%- body %>
</body>
</html>
